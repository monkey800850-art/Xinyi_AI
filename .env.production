# .env.production 配置文件
# DATABASE_URL: 生产环境数据库连接 URL
# SECRET_KEY: 用于加密 session 和 CSRF 防护
# DEBUG: 设置为 False 以禁用调试模式
# FLASK_ENV: 设置为 production 以启用生产环境配置
DATABASE_URL=your_production_db_url_here
SECRET_KEY=your_secret_key_here
DEBUG=False
FLASK_ENV=production
AUTH_SESSION_TIMEOUT_MINUTES=30
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Strict
AUTH_ENABLE_RBAC=1
