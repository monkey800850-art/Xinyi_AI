# App runtime
APP_ENV=development
SECRET_KEY=change_me

# Required DB_* (used by app.config and ops startup precheck)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=xinyi_ai_dev

# Optional URL-style DB vars used by some report/query paths
# DATABASE_URL=mysql+pymysql://root:CHANGE_ME@127.0.0.1:3306/xinyi_ai_dev?charset=utf8mb4
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:CHANGE_ME@127.0.0.1:3306/xinyi_ai_dev?charset=utf8mb4
# DB_URL=mysql+pymysql://root:CHANGE_ME@127.0.0.1:3306/xinyi_ai_dev?charset=utf8mb4

# Optional pool tuning
