{
  "form_code": "VAT_GENERAL_MAIN",
  "version": "v1",
  "lines": [
    {
      "line_no": "1",
      "name": "本期销项税额",
      "source": "computed",
      "expr": "from voucher_preview: sum(tax_amount on taxable output) [stage: derived in vat calc]",
      "field_ref": "vat.out_vat"
    },
    {
      "line_no": "2",
      "name": "本期进项税额（抵扣）",
      "source": "computed",
      "expr": "from voucher_preview/pack: vat.in_deduct",
      "field_ref": "vat.in_deduct"
    },
    {
      "line_no": "3",
      "name": "进项税额转出",
      "source": "computed",
      "expr": "from pack: vat.transfer_out",
      "field_ref": "vat.transfer_out"
    },
    {
      "line_no": "20",
      "name": "应纳税额",
      "source": "pack",
      "expr": "vat_payable = out_vat - in_deduct + transfer_out",
      "field_ref": "vat.vat_payable"
    }
  ]
}
